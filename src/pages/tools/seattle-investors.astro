const accessSlug = (access: string) =>
  access
    .toLowerCase()
    .replace(/[^a-z]+/g, "-")
    .replace(/^-|-$/g, "");

const introHref = (firmName: string) => {
  const subject = `Intro request: ${firmName}`;
  const body = `Hi SNØCAP team,\n\nI'd like to be opted in for an introduction to ${firmName}.\n\nA bit about me:\n- Background:\n- Investing experience:\n- What draws me to this fund:\n\nThanks!`;
  return `mailto:hello@snocap.vc?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
};

const chartsDirUrl =
  "https://github.com/snocap/snocap.vc/tree/main/src/data/seattle-investors";
const fullChartEditUrl =
  "https://github.com/snocap/snocap.vc/edit/main/src/data/seattle-investors/full.mmd";
---

<Layout slim={true}>
  <section class="tool-page">
    <div class="tool-header">
      <small class="breadcrumb">SNØCAP / TOOLS</small>
      <h1>Navigating Seattle's Investing Landscape</h1>
      <h5>
        An aspiring-investor's guide to Pacific Northwest venture capital. The
        first question is about <em>how</em> you want to deploy: your appetite for
        diligence, control, and access. The second is about <em>what</em>
        you want exposure to: the specialty inside that path. <strong
          >Click any branch to expand it.</strong
        >
      </h5>
    </div>

    <div class="diagram-container">
      <pre class="mermaid" set:text={topDiagram} />
    </div>

    <div class="meta-links">
      <a href="#full-chart">View the full chart →</a>
      <a href={chartsDirUrl} target="_blank" rel="noopener">
        Contribute to these charts →
      </a>
    </div>

    <div class="legend">
      <span class="legend-item">
        <span class="legend-swatch legend-swatch--climate"></span>
        Climate-aligned
      </span>
      <span class="legend-item">
        <span class="legend-badge access-lp">LP</span>
        Limited partner in a fund
      </span>
      <span class="legend-item">
        <span class="legend-badge access-angel-network">Angel</span>
        Join an accredited group
      </span>
      <span class="legend-item">
        <span class="legend-badge access-direct">Direct</span>
        Solo or operator-led SPV
      </span>
      <span class="legend-item">
        <span class="legend-badge access-studio">Studio</span>
        Studio LP / co-build
      </span>
      <span class="legend-item">
        <span class="legend-badge access-donor">Donor</span>
        Tax-deductible / nonprofit
      </span>
      <span class="legend-item">
        <span class="legend-badge access-institutional">Institutional</span>
        Restricted to corporate / pension / family office
      </span>
    </div>

    <p class="intro-callout">
      Want a warm intro to any of the funds below? Use the <strong
        >Request intro →</strong
      > link on each card. We'll opt you in if it's a fit.
    </p>

    {
      paths.map((path) => (
        <details
          class="path-section"
          id={`path-${path.key}`}
          data-path={path.key}
        >
          <summary class="path-summary">
            <span class="path-icon">{path.icon}</span>
            <span class="path-label">{path.label}</span>
            <span class="path-toggle" aria-hidden="true" />
          </summary>
          <div class="path-body">
            <p class="path-intro">{path.summary}</p>

            <div class="diagram-container diagram-container--inner">
              <pre class="mermaid" set:text={path.diagram} />
            </div>

            {path.pnwFirms && (
              <div class="firm-grid">
                {path.pnwFirms.map((firm) => (
                  <article
                    class="firm-card"
                    data-climate={firm.climate ? "true" : "false"}
                  >
                    <header>
                      <h3>{firm.name}</h3>
                      <small>
                        {firm.location} · {firm.stage}
                      </small>
                      <span
                        class:list={[
                          "access-badge",
                          `access-${accessSlug(firm.access)}`,
                        ]}
                      >
                        {firm.access}
                      </span>
                    </header>
                    <p>{firm.thesis}</p>
                    {firm.diff && (
                      <p class="firm-diff">
                        <strong>Why this fund: </strong>
                        {firm.diff}
                      </p>
                    )}
                    <div class="firm-actions">
                      <a
                        href={firm.websiteHref}
                        class="firm-link"
                        target="_blank"
                        rel="noopener"
                      >
                        {firm.website}
                      </a>
                      <a href={introHref(firm.name)} class="firm-intro">
                        Request intro →
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            )}

            {path.pnwGroups &&
              path.pnwGroups.map((group) => (
                <div class="firm-group">
                  {group.label && (
                    <h4 class="firm-group-label">{group.label}</h4>
                  )}
                  <div class="firm-grid">
                    {group.firms.map((firm) => (
                      <article
                        class="firm-card"
                        data-climate={firm.climate ? "true" : "false"}
                      >
                        <header>
                          <h3>{firm.name}</h3>
                          <small>
                            {firm.location} · {firm.stage}
                          </small>
                          <span
                            class:list={[
                              "access-badge",
                              `access-${accessSlug(firm.access)}`,
                            ]}
                          >
                            {firm.access}
                          </span>
                        </header>
                        <p>{firm.thesis}</p>
                        {firm.diff && (
                          <p class="firm-diff">
                            <strong>Why this fund: </strong>
                            {firm.diff}
                          </p>
                        )}
                        <div class="firm-actions">
                          <a
                            href={firm.websiteHref}
                            class="firm-link"
                            target="_blank"
                            rel="noopener"
                          >
                            {firm.website}
                          </a>
                          <a href={introHref(firm.name)} class="firm-intro">
                            Request intro →
                          </a>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              ))}

            {path.honorable.length > 0 && (
              <div class="honorable">
                <h4>
                  Honorable mentions — outside the PNW (with PNW touchpoints)
                </h4>
                <div class="firm-grid firm-grid--compact">
                  {path.honorable.map((firm) => (
                    <article
                      class="firm-card firm-card--honorable"
                      data-climate={firm.climate ? "true" : "false"}
                    >
                      <header>
                        <h3>{firm.name}</h3>
                        <small>
                          {firm.location} · {firm.stage}
                        </small>
                        <span
                          class:list={[
                            "access-badge",
                            `access-${accessSlug(firm.access)}`,
                          ]}
                        >
                          {firm.access}
                        </span>
                      </header>
                      <p>{firm.thesis}</p>
                      {firm.diff && (
                        <p class="firm-diff">
                          <strong>Why this fund: </strong>
                          {firm.diff}
                        </p>
                      )}
                      <div class="firm-actions">
                        <a
                          href={firm.websiteHref}
                          class="firm-link"
                          target="_blank"
                          rel="noopener"
                        >
                          {firm.website}
                        </a>
                        <a href={introHref(firm.name)} class="firm-intro">
                          Request intro →
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )}
          </div>
        </details>
      ))
    }

    <details class="path-section full-chart-section" id="full-chart" open>
      <summary class="path-summary">
        <span class="path-icon">🗺️</span>
        <span class="path-label">Full chart (shareable)</span>
        <span class="path-toggle" aria-hidden="true"></span>
      </summary>
      <div class="path-body">
        <p class="path-intro">
          The same map as a single chart for screenshots, decks, or sharing.
          This chart lives at <code>src/data/seattle-investors/full.mmd</code>;
          the per-section charts in this page are also standalone <code
            >.mmd</code
          >
          files in the same directory. Spot something missing or out of date? <a
            href={fullChartEditUrl}
            target="_blank"
            rel="noopener">Edit full.mmd on GitHub</a
          > and submit a pull request.
        </p>
        <div class="diagram-container diagram-container--inner">
          <pre class="mermaid" set:text={fullDiagram} />
        </div>
      </div>
    </details>

    <div class="tool-footer">
      <p>
        Want to back the next wave of physical-IP companies coming out of the
        Pacific Northwest? <a
          href="mailto:hello@snocap.vc?subject=LP%20interest"
          >Get in touch about LP opportunities at SNØCAP</a
        >.
      </p>
    </div>
  </section>
</Layout>

<script>
  import mermaid from "mermaid";

  declare global {
    interface Window {
      expandPath: (key: string) => void;
    }
  }

  window.expandPath = function (key: string) {
    const target = document.getElementById("path-" + key);
    if (!target) return;
    (target as HTMLDetailsElement).open = true;
    setTimeout(function () {
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 60);
  };

  mermaid.initialize({
    startOnLoad: false,
    securityLevel: "loose",
    theme: "base",
    themeVariables: {
      fontFamily: '"NB Akademie Std", Arial, sans-serif',
      fontSize: "14px",
      primaryColor: "#f5f5f5",
      primaryBorderColor: "#9f9f9f",
      primaryTextColor: "#000000",
      secondaryColor: "#ffffff",
      tertiaryColor: "#f0f0f0",
      lineColor: "#9f9f9f",
      nodeTextColor: "#000000",
      mainBkg: "#f5f5f5",
      nodeBorder: "#9f9f9f",
      clusterBkg: "#ffffff",
      edgeLabelBackground: "#ffffff",
    },
    flowchart: {
      htmlLabels: true,
      curve: "basis",
      padding: 16,
      nodeSpacing: 40,
      rankSpacing: 60,
    },
  });

  const renderCharts = () => mermaid.run();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderCharts);
  } else {
    renderCharts();
  }
</script>

<style>
  .tool-page {
    display: flex;
    flex-direction: column;
    padding: 4rem var(--gutter-width) 6rem;
    row-gap: 2.5rem;
    min-height: 80vh;
  }

  .tool-header {
    display: flex;
    flex-direction: column;
    row-gap: 1.25rem;
    max-width: 55rem;
  }

  .breadcrumb {
    color: var(--color-tertiary);
    letter-spacing: 0.1rem;
  }

  h1 {
    font-size: 2.625rem;
    font-weight: 300;
    line-height: 1.1;
  }

  h5 {
    max-width: 45rem;
    color: var(--color-tertiary);
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.55;
  }

  h5 em {
    color: var(--color-primary);
    font-style: italic;
    font-weight: 500;
  }

  h5 strong {
    color: var(--color-primary);
    font-weight: 400;
  }

  .meta-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-size: 0.875rem;
  }

  .meta-links a {
    color: #0d9488;
    border-bottom: 1px solid rgba(13, 148, 136, 0.3);
    padding-bottom: 1px;
  }

  .meta-links a:hover {
    border-bottom-color: #0d9488;
  }

  .intro-callout {
    margin: 0;
    padding: 0.875rem 1.25rem;
    background: rgba(13, 148, 136, 0.06);
    border-left: 3px solid #0d9488;
    color: var(--color-primary);
    font-size: 0.9375rem;
    max-width: 55rem;
  }

  .intro-callout strong {
    font-weight: 500;
    color: #0d9488;
  }

  .diagram-container {
    width: 100%;
    overflow-x: auto;
    padding: 1rem 0;
  }

  .diagram-container--inner {
    padding: 0.5rem 0;
  }

  .mermaid {
    display: flex;
    justify-content: center;
    font-family: var(--font-family);
    background: none;
    border: none;
  }

  .mermaid svg {
    max-width: 100%;
    height: auto;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    font-size: 0.8125rem;
    color: var(--color-tertiary);
    padding: 1rem 1.25rem;
    background: #fafafa;
    border: 1px solid #e5e5e5;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    column-gap: 0.5rem;
  }

  .legend-swatch {
    display: inline-block;
    width: 0.875rem;
    height: 0.875rem;
    border: 1px solid #9f9f9f;
  }

  .legend-swatch--climate {
    background: #d1fae5;
    border-color: #0d9488;
  }

  .legend-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem 0.18rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.04rem;
    text-transform: uppercase;
    text-align: center;
    line-height: 1;
    border: 1px solid #d9d9d9;
    background: #fff;
    color: var(--color-primary);
  }

  .path-section {
    border: 1px solid #d9d9d9;
    background: #fff;
  }

  .path-section[open] {
    border-color: #0d9488;
  }

  .path-summary {
    display: flex;
    align-items: center;
    column-gap: 0.875rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .path-summary::-webkit-details-marker {
    display: none;
  }

  .path-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .path-label {
    font-size: 1.125rem;
    font-weight: 500;
    flex-grow: 1;
  }

  .path-toggle {
    width: 0.625rem;
    height: 0.625rem;
    border-right: 2px solid #6b7280;
    border-bottom: 2px solid #6b7280;
    transform: rotate(-45deg);
    transition: transform 0.2s;
  }

  .path-section[open] .path-toggle {
    transform: rotate(45deg);
  }

  .path-body {
    padding: 0 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    row-gap: 1.5rem;
  }

  .path-intro {
    color: var(--color-tertiary);
    max-width: 50rem;
    margin: 0;
  }

  .firm-group {
    display: flex;
