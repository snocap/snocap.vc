{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:charts && astro build",
    "generate:charts": "node scripts/generate-charts.mjs",
    "optimize-deck": "node scripts/optimize-deck-images.mjs",
    "pdf": "node scripts/generate-pdf.mjs",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "astro": "^5.7.2",
    "modern-normalize": "^3.0.1",
    "sharp": "^0.34.5",
    "typewriter-effect": "^2.21.0"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^24.0.0"
  },
  "lint-staged": {
    "*.{astro,mjs,ts,json,css,yml}": "prettier --write"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ]
  }
}
